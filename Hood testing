    panel.BackgroundColor3=BG; panel.BorderSizePixel=0
    Instance.new("UICorner", panel).CornerRadius=UDim.new(0,10)
    Instance.new("UIStroke", panel).Color=ACCENT

    local titleB = Instance.new("Frame", panel)
    titleB.Size=UDim2.new(1,0,0,34); titleB.BackgroundColor3=PANEL; titleB.BorderSizePixel=0
    Instance.new("UICorner", titleB).CornerRadius=UDim.new(0,10)
    local ff = Instance.new("Frame", titleB)
    ff.Size=UDim2.new(1,0,0.5,0); ff.Position=UDim2.new(0,0,0.5,0); ff.BackgroundColor3=PANEL; ff.BorderSizePixel=0
    local tl = Instance.new("TextLabel", titleB)
    tl.Size=UDim2.new(1,-10,1,0); tl.Position=UDim2.new(0,10,0,0); tl.BackgroundTransparency=1
    tl.Text="ESP  [RShift]"; tl.TextColor3=TEXT; tl.Font=Enum.Font.GothamBold; tl.TextSize=13
    tl.TextXAlignment=Enum.TextXAlignment.Left

    local area = Instance.new("Frame", panel)
    area.Size=UDim2.new(1,-16,1,-42); area.Position=UDim2.new(0,8,0,38); area.BackgroundTransparency=1
    Instance.new("UIListLayout", area).Padding=UDim.new(0,5)

    local function addToggle(label, state, cb)
        local row = Instance.new("Frame", area)
        row.Size=UDim2.new(1,0,0,32); row.BackgroundColor3=ROW; row.BorderSizePixel=0
        Instance.new("UICorner", row).CornerRadius=UDim.new(0,6)
        local l = Instance.new("TextLabel", row)
        l.Size=UDim2.new(1,-50,1,0); l.Position=UDim2.new(0,10,0,0); l.BackgroundTransparency=1
        l.Text=label; l.TextColor3=TEXT; l.Font=Enum.Font.Gotham; l.TextSize=12
        l.TextXAlignment=Enum.TextXAlignment.Left
        local pill = Instance.new("TextButton", row)
        pill.Size=UDim2.fromOffset(38,20); pill.Position=UDim2.new(1,-46,0.5,-10)
        pill.Text=""; pill.BackgroundColor3=state and ON or OFF; pill.BorderSizePixel=0
        Instance.new("UICorner", pill).CornerRadius=UDim.new(0.5,0)
        local knob = Instance.new("Frame", pill)
        knob.Size=UDim2.fromOffset(14,14); knob.BackgroundColor3=Color3.fromRGB(255,255,255)
        knob.BorderSizePixel=0; knob.Position=state and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)
        Instance.new("UICorner", knob).CornerRadius=UDim.new(0.5,0)
        pill.MouseButton1Click:Connect(function()
            state = not state
            pill.BackgroundColor3 = state and ON or OFF
            knob.Position = state and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)
            cb(state)
        end)
    end

    addToggle("ESP",        true, function(v) ESP.enabled  = v end)
    addToggle("Skeleton",   true, function(v) ESP.skeleton = v end)
    addToggle("Chams",      true, function(v) ESP.chams    = v end)
    addToggle("Names",      true, function(v) ESP.names    = v end)
    addToggle("Health Bar", true, function(v) ESP.health   = v end)

    local drag, ds, dp
    titleB.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then drag=true; ds=i.Position; dp=panel.Position end
    end)
    UIS.InputChanged:Connect(function(i)
        if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
            local d = i.Position - ds
            panel.Position = UDim2.new(dp.X.Scale, dp.X.Offset+d.X, dp.Y.Scale, dp.Y.Offset+d.Y)
        end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
    end)
    UIS.InputBegan:Connect(function(i, gp)
        if gp then return end
        if i.KeyCode == Enum.KeyCode.RightShift then panel.Visible = not panel.Visible end
    end)

    print("[ESP] Loaded")
end

