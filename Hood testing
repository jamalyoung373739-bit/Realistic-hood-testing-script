-- ── ESP ─────────────────────────────────────────────────────
do
    local old = gethui():FindFirstChild("HoodESP")
    if old then old:Destroy() end

    local ESP = {
        enabled   = true,
        skeleton  = true,
        chams     = true,
        names     = true,
        health    = true,
        skelColor = Color3.fromRGB(255, 255, 255),
        nameColor = Color3.fromRGB(255, 255, 255),
        chamFill  = Color3.fromRGB(255, 50,  50),
        chamOut   = Color3.fromRGB(255, 255, 255),
    }

    local BONES = {
        {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
        {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
        {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
        {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
        {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},
    }
    local cache = {}

    local function mkL(col, th)
        local l = Drawing.new("Line")
        l.Thickness = th or 1.2; l.Color = col or Color3.fromRGB(255,255,255)
        l.Transparency = 1; l.Visible = false; return l
    end
    local function mkT(sz, col)
        local t = Drawing.new("Text")
        t.Size = sz or 13; t.Color = col or Color3.fromRGB(255,255,255)
        t.Center = true; t.Outline = true; t.Font = Drawing.Fonts.UI
        t.Transparency = 1; t.Visible = false; return t
    end

    local function buildFor(p)
        if cache[p] then return end
        local o = {bones={}, name=mkT(13), hpBg=mkL(Color3.fromRGB(40,40,40),3), hpBar=mkL(nil,3), hpTxt=mkT(10)}
        for _ = 1, #BONES do o.bones[#o.bones+1] = mkL(ESP.skelColor, 1.2) end
        local hi = Instance.new("Highlight")
        hi.FillColor = ESP.chamFill; hi.OutlineColor = ESP.chamOut
        hi.FillTransparency = 0.5; hi.OutlineTransparency = 0
        hi.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop; hi.Enabled = false
        if p.Character then hi.Adornee = p.Character; hi.Parent = p.Character end
        o.hi = hi; cache[p] = o
    end
    local function wipeFor(p)
        local o = cache[p]; if not o then return end
        pcall(function() o.hi:Destroy() end)
        for _, d in ipairs{o.name, o.hpBg, o.hpBar, o.hpTxt} do pcall(function() d:Remove() end) end
        for _, l in ipairs(o.bones) do pcall(function() l:Remove() end) end
        cache[p] = nil
    end

    for _, p in ipairs(Players:GetPlayers()) do if p ~= me then buildFor(p) end end
    Players.PlayerAdded:Connect(function(p)
        p.CharacterAdded:Connect(function() task.wait(1); buildFor(p) end); buildFor(p)
    end)
    Players.PlayerRemoving:Connect(wipeFor)
    me.CharacterAdded:Connect(function()
        task.wait(1)
        for _, p in ipairs(Players:GetPlayers()) do if p ~= me then buildFor(p) end end
    end)

    RunSvc.RenderStepped:Connect(function()
        for _, p in ipairs(Players:GetPlayers()) do
            if p == me then continue end
            local o = cache[p]; if not o then continue end
            local char = p.Character
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")

            if o.hi then
                if char and o.hi.Adornee ~= char then o.hi.Adornee = char; o.hi.Parent = char end
                o.hi.FillColor = ESP.chamFill; o.hi.OutlineColor = ESP.chamOut
                o.hi.Enabled = ESP.enabled and ESP.chams and char ~= nil
            end

            if not ESP.enabled or not char or not hrp or not hum then
                o.name.Visible=false; o.hpBg.Visible=false; o.hpBar.Visible=false; o.hpTxt.Visible=false
                for _, l in ipairs(o.bones) do l.Visible = false end
                continue
            end

            local _, vis = Camera:WorldToViewportPoint(hrp.Position)
            if not vis then
                o.name.Visible=false; o.hpBg.Visible=false; o.hpBar.Visible=false; o.hpTxt.Visible=false
                for _, l in ipairs(o.bones) do l.Visible = false end
                continue
            end

            local head = char:FindFirstChild("Head")
            if ESP.names and head then
                local hs = Camera:WorldToViewportPoint(head.Position + Vector3.new(0,1,0))
                o.name.Text = p.Name; o.name.Color = ESP.nameColor
                o.name.Position = Vector2.new(hs.X, hs.Y); o.name.Visible = true
            else o.name.Visible = false end

            for i, pair in ipairs(BONES) do
                local ln = o.bones[i]
                if ESP.skeleton then
                    local pA = char:FindFirstChild(pair[1]); local pB = char:FindFirstChild(pair[2])
                    if pA and pB then
                        local sA, oA = Camera:WorldToViewportPoint(pA.Position)
                        local sB, oB = Camera:WorldToViewportPoint(pB.Position)
                        if oA and oB then
                            ln.From = Vector2.new(sA.X,sA.Y); ln.To = Vector2.new(sB.X,sB.Y)
                            ln.Color = ESP.skelColor; ln.Visible = true
                        else ln.Visible = false end
                    else ln.Visible = false end
                else ln.Visible = false end
            end

            local foot = char:FindFirstChild("LeftFoot") or char:FindFirstChild("RightFoot") or hrp
            if ESP.health and head and foot then
                local sH = Camera:WorldToViewportPoint(head.Position + Vector3.new(0,0.6,0))
                local sF = Camera:WorldToViewportPoint(foot.Position - Vector3.new(0,0.3,0))
                local topY = math.min(sH.Y,sF.Y); local botY = math.max(sH.Y,sF.Y); local lx = sH.X-14
                local hp = math.clamp(hum.Health / math.max(hum.MaxHealth,1), 0, 1)
                o.hpBg.From=Vector2.new(lx,topY); o.hpBg.To=Vector2.new(lx,botY); o.hpBg.Visible=true
                o.hpBar.Color = Color3.fromRGB(math.floor(255*(1-hp)), math.floor(255*hp), 0)
                o.hpBar.From=Vector2.new(lx,botY); o.hpBar.To=Vector2.new(lx,botY-(botY-topY)*hp); o.hpBar.Visible=true
                o.hpTxt.Text=math.ceil(hum.Health).."HP"; o.hpTxt.Position=Vector2.new(lx-1,(topY+botY)/2); o.hpTxt.Visible=true
            else o.hpBg.Visible=false; o.hpBar.Visible=false; o.hpTxt.Visible=false end
        end
    end)

    -- GUI panel (RShift to toggle)
    local ACCENT = Color3.fromRGB(110,70,210)
    local BG     = Color3.fromRGB(14,12,22)
    local PANEL  = Color3.fromRGB(22,19,36)
    local ROW    = Color3.fromRGB(30,26,48)
    local TEXT   = Color3.fromRGB(220,215,235)
    local ON     = Color3.fromRGB(100,220,100)
